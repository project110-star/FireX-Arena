<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Match</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Poppins,sans-serif;
}

body{
    background:#0b0b0b;
    color:#fff;
    padding:20px;
}

h1{
    text-align:center;
    color:#ffb400;
    margin-bottom:20px;
}

.match{
    background:#181818;
    padding:15px;
    border-radius:12px;
    margin-bottom:15px;
    border-left:4px solid #ffb400;
}

.match h3{
    color:#ffb400;
    margin-bottom:10px;
}

.match img{
    width:100%;
    height:180px;
    object-fit:cover;
    border-radius:10px;
    margin-bottom:10px;
}

button{
    width:100%;
    padding:12px;
    border:none;
    border-radius:10px;
    background:#ffb400;
    color:#000;
    font-weight:bold;
    margin-top:10px;
    cursor:pointer;
}
</style>
</head>

<body>

<h1>✏️ Edit Matches</h1>
<div id="matchList"></div>

<script type="module">

import { initializeApp } from "https://www.gstatic.com/firebasejs/12.15.0/firebase-app.js";

import {
    getFirestore,
    collection,
    onSnapshot,
    doc,
    updateDoc
} from "https://www.gstatic.com/firebasejs/12.15.0/firebase-firestore.js";

import {
    getAuth,
    onAuthStateChanged
} from "https://www.gstatic.com/firebasejs/12.15.0/firebase-auth.js";

/* Firebase Config */
const firebaseConfig = {
    apiKey: "AIzaSyB-xmpOXOANK5_4LWApxcjaifI8-7GsTzM",
    authDomain: "ff-tournament-eb06d.firebaseapp.com",
    projectId: "ff-tournament-eb06d",
    messagingSenderId: "265955776563",
    appId: "1:265955776563:web:a50c1a8e6151c777242b46"
};

const app = initializeApp(firebaseConfig);
const db = getFirestore(app);
const auth = getAuth(app);

const matchList = document.getElementById("matchList");

/* CHECK LOGIN FIRST */
onAuthStateChanged(auth, (user) => {

    if (!user) {
        matchList.innerHTML = "<p style='color:red;text-align:center'>Please login first</p>";
        return;
    }

    loadMatches();
});

/* LOAD MATCHES */
function loadMatches() {

    onSnapshot(collection(db, "matches"), (snapshot) => {

        matchList.innerHTML = "";

        if (snapshot.empty) {
            matchList.innerHTML = "<p style='text-align:center'>No Matches Found</p>";
            return;
        }

        snapshot.forEach((d) => {

            let m = d.data();

            let div = document.createElement("div");
            div.className = "match";

            div.innerHTML = `
                <img src="${m.image || 'https://via.placeholder.com/400x180'}">

                <h3>${m.name || "No Name"}</h3>

                <p>Entry Fee : ₹${m.entryFee || 0}</p>
                <p>Prize Pool : ₹${m.prizePool || 0}</p>
                <p>Room ID : ${m.roomId || "-"}</p>
                <p>Password : ${m.roomPass || "-"}</p>
                <p>Status : ${m.status || "upcoming"}</p>

                <button class="editBtn">EDIT MATCH</button>
            `;

            div.querySelector(".editBtn").onclick = async () => {

                let name = prompt("Match Name", m.name || "");
                if (name === null) return;

                let entryFee = prompt("Entry Fee", m.entryFee || "");
                let prizePool = prompt("Prize Pool", m.prizePool || "");
                let roomId = prompt("Room ID", m.roomId || "");
                let roomPass = prompt("Room Password", m.roomPass || "");
                let status = prompt("Status (upcoming/live/finished)", m.status || "upcoming");
                let image = prompt("Image URL", m.image || "");

                try {
                    await updateDoc(doc(db, "matches", d.id), {
                        name,
                        entryFee: Number(entryFee),
                        prizePool: Number(prizePool),
                        roomId,
                        roomPass,
                        status,
                        image
                    });

                    alert("Match Updated Successfully ✔");

                } catch (err) {
                    console.log(err);
                    alert("Error: " + err.message);
                }
            };

            matchList.appendChild(div);
        });

    }, (error) => {
        console.log(error);
        matchList.innerHTML = `
        <p style="color:red;text-align:center">
        Permission Denied / Firestore Rules Issue
        </p>
        `;
    });
}

</script>

</body>
</html>